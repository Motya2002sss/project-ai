APP_NAME=AI Life Planner
APP_ENV=local
APP_DEBUG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_life_planner
POSTGRES_USER=ai_life_planner
POSTGRES_PASSWORD=ai_life_planner_password

DATABASE_URL=postgresql+psycopg://ai_life_planner:ai_life_planner_password@localhost:5432/ai_life_planner

TELEGRAM_BOT_TOKEN=

PLAN_START_BUFFER_MINUTES=30
DEFAULT_PLAN_START_TIME=18:30

# mock = локальный fallback без реальной нейронки
# openai = OpenAI API
# openai-compatible = OpenAI-compatible endpoint
# ollama = native Ollama /api/chat endpoint
LLM_ENABLED=false
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_INPUT_CHARS=1500
LLM_MAX_OUTPUT_TOKENS=250
LLM_OLLAMA_THINK=false
LLM_EVAL_STRICT=false
