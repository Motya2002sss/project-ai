APP_NAME=AI Life Planner
APP_ENV=local
APP_DEBUG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_life_planner
POSTGRES_USER=ai_life_planner
POSTGRES_PASSWORD=ai_life_planner_password

DATABASE_URL=postgresql+psycopg://ai_life_planner:ai_life_planner_password@localhost:5432/ai_life_planner

TELEGRAM_BOT_TOKEN=

# mock = локальный fallback без реальной нейронки
# openai = OpenAI API
# custom = OpenAI-compatible endpoint
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
